SECRET_KEY=change-me-to-a-random-value
# relative sqlite path -- Flask-SQLAlchemy resolves this under instance_path automatically,
# i.e. this ends up at instance/app.db. Don't prefix it with "instance/" yourself or it
# doubles up to instance/instance/app.db.
DATABASE_URL=sqlite:///app.db
# config.py defaults this to true (production-safe). Override to false ONLY for local
# http://localhost dev -- omit this line entirely (or set true) for any real deployment.
SESSION_COOKIE_SECURE=false

# app.py defaults this to false (production-safe -- no stack traces/source/RCE console
# on error). Uncomment ONLY for local interactive debugging; never set true for any
# real deployment/demo.
# FLASK_DEBUG=true
